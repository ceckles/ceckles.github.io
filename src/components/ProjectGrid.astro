---
import { featuredProjects } from '../data/projects.js';
import ProjectCard from './ProjectCard.astro';
---

<section id="projects" class="section">
  <p class="section-label reveal">03 · Projects</p>
  <h2 class="section-title reveal">Featured work</h2>
  <p class="reveal mt-3 max-w-2xl text-ink-dim">
    A handful of projects from my GitHub — each links out to source, a live demo where available, and a deeper case study.
  </p>

  <div class="mt-12 grid gap-8 sm:grid-cols-2">
    {featuredProjects.map((project) => <ProjectCard project={project} />)}
  </div>
</section>
