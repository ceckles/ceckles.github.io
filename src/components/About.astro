---
import { profile } from '../data/links.js';
import { stats } from '../data/skills.js';
---

<section id="about" class="section">
  <p class="section-label reveal">01 · About</p>
  <h2 class="section-title reveal">A little about me</h2>

  <div class="mt-10 grid gap-12 md:grid-cols-[1.4fr_1fr]">
    <div class="reveal space-y-5 text-base leading-relaxed text-ink-dim sm:text-lg">
      <p>{profile.intro}</p>
      <p>
        Currently building at <span class="font-mono text-accent">{profile.company}</span>, based in{' '}
        {profile.location}.
      </p>
      <p class="border-l-2 border-accent/40 pl-4 text-ink-dim">
        <span class="font-mono text-sm uppercase tracking-wide text-accent">Fun fact —</span>{' '}
        {profile.funFact}
      </p>
    </div>

    <dl class="reveal grid grid-cols-2 gap-4">
      {
        stats.map((stat) => (
          <div class="card px-5 py-6 text-center">
            <dd class="font-mono text-3xl font-bold text-accent">{stat.value}</dd>
            <dt class="mt-1 text-xs uppercase tracking-wide text-ink-dim">{stat.label}</dt>
          </div>
        ))
      }
    </dl>
  </div>
</section>
