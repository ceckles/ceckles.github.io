---
interface Props {
  project: {
    slug: string;
    title: string;
    tagline: string;
    tech: string[];
    github: string;
    demo: string | null;
    noScreenshot?: boolean;
    stars: number;
    outcome: string;
  };
}
const { project } = Astro.props as Props;

// Live screenshot via WordPress's free mshots service — no API key, no local image storage.
// Falls back to a generic icon for projects with no live demo, or ones flagged noScreenshot
// (e.g. a demo whose backend spins down and gets stuck on a loading state).
// Uses the same w/h as the case-study page so both spots share one cached crawl per project.
const screenshotUrl = project.demo && !project.noScreenshot
  ? `https://s.wordpress.com/mshots/v1/${encodeURIComponent(project.demo)}?w=1200&h=750`
  : null;
---

<article class="card reveal group flex flex-col overflow-hidden transition-all duration-300 hover:-translate-y-1.5 hover:shadow-card-hover">
  <a href={`/projects/${project.slug}/`} class="block">
    {
      screenshotUrl ? (
        <div class="aspect-video overflow-hidden border-b border-white/5 bg-bg-soft">
          <img
            src={screenshotUrl}
            alt={`Screenshot of the live ${project.title} demo`}
            loading="lazy"
            class="h-full w-full object-cover object-top"
          />
        </div>
      ) : (
        <div
          class="flex aspect-video items-center justify-center border-b border-white/5 bg-gradient-to-br from-white/[0.03] to-transparent"
          aria-hidden="true"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" class="h-16 w-16 text-ink-faint/40">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.75 4.5 12l5.25 8.25M14.25 3.75 19.5 12l-5.25 8.25" />
          </svg>
        </div>
      )
    }
  </a>

  <div class="flex flex-1 flex-col gap-3 p-6">
    <div class="flex items-start justify-between gap-3">
      <h3 class="text-lg font-bold text-ink">
        <a href={`/projects/${project.slug}/`} class="hover:text-accent">{project.title}</a>
      </h3>
      {
        project.stars > 0 && (
          <span class="flex shrink-0 items-center gap-1 font-mono text-xs text-ink-faint">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-3.5 w-3.5 text-accent">
              <path d="M9.05 2.94a1 1 0 0 1 1.9 0l1.44 3.13 3.42.34a1 1 0 0 1 .57 1.75l-2.6 2.32.77 3.4a1 1 0 0 1-1.48 1.08L10 13.28l-3.07 1.68a1 1 0 0 1-1.48-1.08l.77-3.4-2.6-2.32a1 1 0 0 1 .57-1.75l3.42-.34 1.44-3.13Z" />
            </svg>
            {project.stars}
          </span>
        )
      }
    </div>

    <p class="text-sm text-ink-dim">{project.tagline}</p>
    <p class="text-sm text-ink-faint">{project.outcome}</p>

    <ul class="mt-1 flex flex-wrap gap-2">
      {
        project.tech.map((t) => (
          <li class="rounded-full border border-accent/20 bg-accent/5 px-2.5 py-1 font-mono text-[11px] text-accent-soft">
            {t}
          </li>
        ))
      }
    </ul>

    <div class="mt-auto flex items-center gap-4 pt-4">
      <a
        href={project.github}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 font-mono text-sm text-ink-dim hover:text-accent"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
          <path d="M12 .5C5.73.5.98 5.24.98 11.52c0 4.94 3.2 9.13 7.65 10.61.56.1.76-.24.76-.54 0-.27-.01-1.15-.02-2.09-3.11.68-3.77-1.32-3.77-1.32-.51-1.3-1.24-1.65-1.24-1.65-1.01-.7.08-.68.08-.68 1.12.08 1.71 1.15 1.71 1.15 1 1.71 2.62 1.22 3.26.93.1-.72.39-1.22.71-1.5-2.48-.28-5.1-1.24-5.1-5.53 0-1.22.44-2.22 1.15-3-.11-.28-.5-1.42.11-2.96 0 0 .93-.3 3.05 1.14a10.6 10.6 0 0 1 5.56 0c2.12-1.44 3.05-1.14 3.05-1.14.61 1.54.22 2.68.11 2.96.72.78 1.15 1.78 1.15 3 0 4.3-2.62 5.24-5.12 5.52.4.35.76 1.03.76 2.08 0 1.5-.01 2.71-.01 3.08 0 .3.2.65.77.54A11.03 11.03 0 0 0 23.02 11.5C23.02 5.24 18.27.5 12 .5Z"/>
        </svg>
        Code
      </a>
      {
        project.demo && (
          <a
            href={project.demo}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 font-mono text-sm text-ink-dim hover:text-accent"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H18v4.5M18 6l-8 8M9 6H6a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2-2v-3" />
            </svg>
            Live Demo
          </a>
        )
      }
      <a
        href={`/projects/${project.slug}/`}
        class="ml-auto font-mono text-sm text-accent hover:underline"
      >
        Case study →
      </a>
    </div>
  </div>
</article>
