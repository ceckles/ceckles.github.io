---

<section id="contact" class="section">
  <div class="card reveal mx-auto max-w-3xl px-6 py-14 text-center sm:px-14">
    <p class="section-label justify-center">07 · Contact</p>
    <h2 class="section-title">Interested in working together?</h2>
    <p class="mt-4 text-ink-dim">
      Open to full-time roles, freelance projects, and consulting work. Use the form below —
      I usually respond within 1–2 business days.
    </p>

    <!--
      Form posts to Formspree (https://formspree.io) — free tier, no backend required on GitHub Pages.
      TODO: sign up at formspree.io, create a form, and replace YOUR_FORM_ID below.
    -->
    <form
      action="https://formspree.io/f/YOUR_FORM_ID"
      method="POST"
      class="mx-auto mt-10 flex max-w-xl flex-col gap-4 text-left"
    >
      <div>
        <label for="name" class="mb-1.5 block font-mono text-xs uppercase tracking-wide text-ink-dim">
          Name
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="w-full rounded-md border border-white/10 bg-bg-soft px-4 py-3 text-ink placeholder:text-ink-faint focus:border-accent focus:outline-none"
          placeholder="Your name"
        />
      </div>
      <div>
        <label for="email" class="mb-1.5 block font-mono text-xs uppercase tracking-wide text-ink-dim">
          Email
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full rounded-md border border-white/10 bg-bg-soft px-4 py-3 text-ink placeholder:text-ink-faint focus:border-accent focus:outline-none"
          placeholder="you@example.com"
        />
      </div>
      <div>
        <label for="message" class="mb-1.5 block font-mono text-xs uppercase tracking-wide text-ink-dim">
          Message
        </label>
        <textarea
          id="message"
          name="message"
          required
          rows="5"
          class="w-full rounded-md border border-white/10 bg-bg-soft px-4 py-3 text-ink placeholder:text-ink-faint focus:border-accent focus:outline-none"
          placeholder="Full-time, freelance, or consulting — tell me a bit about it."
        ></textarea>
      </div>
      <button type="submit" class="btn-primary mt-2 w-full sm:w-auto sm:self-start">
        Send message
      </button>
    </form>
  </div>
</section>
