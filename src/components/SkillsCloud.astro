---
import { skillGroups } from '../data/skills.js';
---

<section id="skills" class="section">
  <p class="section-label reveal">02 · Skills</p>
  <h2 class="section-title reveal">Tools of the trade</h2>

  <div class="mt-12 space-y-12">
    {
      skillGroups.map((group) => (
        <div class="reveal">
          <h3 class="mb-4 font-mono text-sm uppercase tracking-[0.2em] text-ink-faint">
            {group.category}
          </h3>
          <ul class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
            {
              group.items.map((item) => (
                <li class="card flex flex-col items-center gap-2 px-3 py-5 text-center transition-transform hover:-translate-y-1 hover:shadow-card-hover">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.6"
                    class="h-7 w-7 text-accent"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.75 4.5 12l5.25 8.25M14.25 3.75 19.5 12l-5.25 8.25" />
                  </svg>
                  <span class="font-mono text-xs text-ink-dim sm:text-sm">{item.name}</span>
                </li>
              ))
            }
          </ul>
        </div>
      ))
    }
  </div>
</section>
