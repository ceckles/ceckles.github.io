---
import { experience } from '../data/experience.js';
---

<section id="experience" class="section">
  <p class="section-label reveal">06 · Experience</p>
  <h2 class="section-title reveal">Where I've been</h2>

  <ol class="relative mt-12 space-y-10 border-l border-white/10 pl-8">
    {
      experience.map((item) => (
        <li class="reveal relative">
          <span class="absolute -left-[2.35rem] top-1.5 h-3 w-3 rounded-full border-2 border-accent bg-bg" />
          <p class="font-mono text-xs uppercase tracking-wide text-accent">{item.dates}</p>
          <h3 class="mt-1 text-lg font-bold text-ink">
            {item.role} <span class="text-ink-faint">· {item.company}</span>
          </h3>
          <p class="mt-2 max-w-2xl text-sm text-ink-dim">{item.description}</p>
          {item.tech.length > 0 && (
            <ul class="mt-3 flex flex-wrap gap-2">
              {item.tech.map((t) => (
                <li class="rounded-full border border-accent/20 bg-accent/5 px-2.5 py-1 font-mono text-[11px] text-accent-soft">
                  {t}
                </li>
              ))}
            </ul>
          )}
        </li>
      ))
    }
  </ol>
</section>
