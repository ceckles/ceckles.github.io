---
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/projects.js';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { caseStudy } = project;
---

<Layout
  title={`${project.title} — Case Study | Chad Eckles`}
  description={project.description}
>
  <article class="section max-w-3xl">
    <a href="/#projects" class="font-mono text-sm text-ink-dim hover:text-accent">&larr; Back to projects</a>

    <p class="section-label mt-8">Case Study</p>
    <h1 class="text-4xl font-extrabold tracking-tight text-ink sm:text-5xl">{project.title}</h1>
    <p class="mt-4 text-lg text-ink-dim">{project.tagline}</p>

    <ul class="mt-6 flex flex-wrap gap-2">
      {
        project.tech.map((t) => (
          <li class="rounded-full border border-accent/20 bg-accent/5 px-3 py-1 font-mono text-xs text-accent-soft">
            {t}
          </li>
        ))
      }
    </ul>

    <div class="mt-6 flex flex-wrap gap-4">
      <a href={project.github} target="_blank" rel="noopener noreferrer" class="btn-secondary">
        View on GitHub
      </a>
      {
        project.demo && (
          <a href={project.demo} target="_blank" rel="noopener noreferrer" class="btn-primary">
            Live Demo
          </a>
        )
      }
    </div>

    <div class="card my-12 flex aspect-video items-center justify-center" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="h-20 w-20 text-ink-faint/30">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.75 4.5 12l5.25 8.25M14.25 3.75 19.5 12l-5.25 8.25" />
      </svg>
    </div>

    <div class="prose prose-invert max-w-none space-y-10">
      <section>
        <h2 class="font-mono text-sm uppercase tracking-[0.2em] text-accent">Problem &amp; Context</h2>
        <p class="mt-3 text-ink-dim leading-relaxed">{caseStudy.problem}</p>
      </section>

      <section>
        <h2 class="font-mono text-sm uppercase tracking-[0.2em] text-accent">Constraints &amp; Tradeoffs</h2>
        <p class="mt-3 text-ink-dim leading-relaxed">{caseStudy.constraints}</p>
      </section>

      <section>
        <h2 class="font-mono text-sm uppercase tracking-[0.2em] text-accent">Architecture</h2>
        <p class="mt-3 text-ink-dim leading-relaxed">{caseStudy.architecture}</p>
        <div class="card mt-4 flex items-center justify-center p-10 text-center font-mono text-xs text-ink-faint">
          [ architecture / data-flow diagram — drop an image or embed here ]
        </div>
      </section>

      <section>
        <h2 class="font-mono text-sm uppercase tracking-[0.2em] text-accent">Results</h2>
        <ul class="mt-3 list-inside list-disc space-y-1 text-ink-dim">
          {caseStudy.results.map((r: string) => <li>{r}</li>)}
        </ul>
      </section>

      <section>
        <h2 class="font-mono text-sm uppercase tracking-[0.2em] text-accent">Lessons Learned</h2>
        <p class="mt-3 text-ink-dim leading-relaxed">{caseStudy.lessons}</p>
      </section>
    </div>
  </article>
</Layout>
